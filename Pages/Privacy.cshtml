@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacidad";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#667eea" />
    <title>@ViewData["Title"]</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; flex-direction: column }
        .header { background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1); padding: 15px }
        .header-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center }
        .logo { font-size: 20px; font-weight: bold; color: #333; text-decoration: none }
        .btn { padding: 10px 16px; border: none; cursor: pointer; border-radius: 8px; text-decoration: none; display: inline-block; font-size: 14px; font-weight: 600; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white }
        .main-content { flex: 1; max-width: 800px; margin: 0 auto; padding: 20px; width: 100% }
        .content-box { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); margin-bottom: 20px }
        .content-box h1 { color: #333; margin-bottom: 20px; font-size: 24px }
        .content-box h2 { color: #667eea; margin: 20px 0 10px 0; font-size: 18px }
        .content-box p { color: #666; margin-bottom: 15px; line-height: 1.6; font-size: 15px }
        .content-box ul { margin-left: 20px; margin-bottom: 15px; color: #666 }
        .content-box li { margin-bottom: 8px; line-height: 1.6 }
        .footer { background: #333; color: white; padding: 20px; text-align: center }
        .footer a { color: #25D366; text-decoration: none }
        @@media(max-width: 768px) {
            .header-content { flex-direction: column; gap: 10px }
            .content-box { padding: 20px }
            .content-box h1 { font-size: 20px }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="header-content">
            <a href="/" class="logo">🥩 Carnicería</a>
            <a href="/" class="btn">← Volver</a>
        </div>
    </header>
    <main class="main-content">
        <div class="content-box">
            <h1>🔒 Política de Privacidad</h1>
            
            <h2>Información que recopilamos</h2>
            <p>En nuestra carnicería online, solo recopilamos la información necesaria para procesar tus pedidos:</p>
            <ul>
                <li>Nombre y apellido</li>
                <li>Teléfono de contacto</li>
                <li>Dirección de entrega</li>
                <li>Notas del pedido</li>
            </ul>
            
            <h2>Uso de la información</h2>
            <p>La información que recopilamos se utiliza exclusivamente para:</p>
            <ul>
                <li>Procesar y preparar tus pedidos de carne</li>
                <li>Contactarte sobre tu compra (confirmación, entrega)</li>
                <li>Coordinar horarios de entrega o retiro</li>
                <li>Mejorar nuestro servicio</li>
            </ul>
            
            <h2>Protección de datos</h2>
            <p>Implementamos medidas de seguridad adecuadas para proteger tu información personal contra acceso no autorizado, alteración, divulgación o destrucción.</p>
            
            <h2>Compartir información</h2>
            <p><strong>No compartimos, vendemos ni alquilamos</strong> tu información personal con terceros. Solo la utilizamos para procesar tus pedidos a través de WhatsApp.</p>
            
            <h2>Tus derechos</h2>
            <p>Tenés derecho a:</p>
            <ul>
                <li>Acceder a tu información personal</li>
                <li>Corregir datos incorrectos</li>
                <li>Solicitar la eliminación de tus datos</li>
                <li>Oponerte al procesamiento de tus datos</li>
            </ul>
            
            <h2>Contacto</h2>
            <p>Si tenés alguna pregunta sobre esta política de privacidad, no dudes en contactarnos:</p>
            <ul>
                <li>📱 WhatsApp: (ver en la app)</li>
                <li>📍 Dirección: (ver en la app)</li>
            </ul>
            
            <p style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; color: #999; font-size: 13px;">
                Última actualización: @DateTime.Now.ToString("dd/MM/yyyy")
            </p>
        </div>
    </main>
    <footer class="footer">
        <p>&copy; @DateTime.Now.Year - Carnicería WhatsApp</p>
    </footer>
</body>
</html>
