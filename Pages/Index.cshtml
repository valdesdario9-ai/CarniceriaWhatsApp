@page
@model IndexModel
@{
    ViewData["Title"] = Model.Config?.NombreTienda ?? "Carnicería";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box }
        body { font-family: system-ui, sans-serif; background: linear-gradient(135deg, #667eea, #764ba2); min-height: 100vh; display: flex; flex-direction: column }
        
        /* ✅ Header optimizado para móvil */
        .header { background: white; padding: 12px 10px; position: sticky; top: 0; box-shadow: 0 2px 5px rgba(0,0,0,0.1); z-index: 100 }
        .header-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap }
        
        /* ✅ Logo más grande y destacado */
        .logo { 
            font-size: 22px; 
            font-weight: 700; 
            color: #333; 
            text-align: center; 
            flex: 1; 
            min-width: 0; 
            word-wrap: break-word; 
            white-space: normal; 
            line-height: 1.4;
            text-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }
        
        .nav { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center }
        .btn { padding: 8px 12px; border: none; border-radius: 6px; text-decoration: none; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; font-size: 13px; white-space: nowrap }
        .btn-cart { background: #25D366; color: white }
        .btn-admin { background: #667eea; color: white }
        
        .main { flex: 1; max-width: 1200px; margin: 0 auto; padding: 15px; width: 100% }
        h1 { color: white; text-align: center; margin-bottom: 20px; font-size: 20px }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px }
        .card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1) }
        .card img { width: 100%; aspect-ratio: 1/1; object-fit: cover }
        .card-body { padding: 10px }
        .name { font-size: 13px; font-weight: 600; color: #333; margin-bottom: 4px; line-height: 1.2 }
        .price { font-size: 15px; color: #28a745; font-weight: 700; margin-bottom: 6px }
        .qty { width: 100%; padding: 6px; border: 2px solid #ddd; border-radius: 6px; margin-bottom: 6px; font-size: 13px }
        .add { width: 100%; padding: 8px; background: #667eea; color: white; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 13px }
        .add:hover { background: #5568d3 }
        .empty { text-align: center; color: white; padding: 40px 20px }
        
        /* ✅ Modales */
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; padding: 10px }
        .modal.show { display: flex }
        .modal-content { background: white; padding: 15px; border-radius: 12px; max-width: 450px; width: 100%; max-height: 90vh; overflow-y: auto }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; padding-bottom: 10px; border-bottom: 1px solid #eee }
        .modal-title { font-size: 16px; font-weight: bold }
        .modal-close { background: none; border: none; font-size: 22px; cursor: pointer; padding: 0 5px }
        .cart-item { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #eee; font-size: 13px }
        .cart-total { font-size: 16px; font-weight: bold; text-align: right; margin: 15px 0 }
        .form-group { margin-bottom: 12px }
        .form-group label { display: block; margin-bottom: 4px; font-weight: 600; font-size: 13px }
        .form-group input, .form-group textarea { width: 100%; padding: 8px; border: 2px solid #ddd; border-radius: 6px; font-size: 14px }
        .btn-checkout { width: 100%; padding: 10px; background: #25D366; color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; margin-top: 10px }
        
        /* ✅ Footer profesional */
        .footer { background: #1a1a2e; color: #aaa; padding: 20px 10px; margin-top: auto; text-align: center; font-size: 12px; line-height: 1.5 }
        .footer-content { max-width: 1200px; margin: 0 auto }
        .footer-developer { color: #667eea; font-weight: 600; text-decoration: none }
        .footer-developer:hover { color: #764ba2 }
        .footer-contact { margin: 8px 0 }
        .footer-contact a { color: #25D366; text-decoration: none; margin: 0 6px; display: inline-block }
        .footer-contact a:hover { text-decoration: underline }
        .footer-version { color: #666; font-size: 11px; margin-top: 6px }
        .footer-flag { margin-right: 3px }
        
        /* ✅ Media Queries para móvil */
        @@media (max-width: 480px) {
            .header { padding: 10px 8px }
            .header-content { flex-direction: column; gap: 10px; text-align: center }
            /* ✅ Logo más grande en móvil también */
            .logo { 
                font-size: 20px; 
                font-weight: 700;
                width: 100%;
                line-height: 1.3;
            }
            .nav { width: 100%; justify-content: center }
            .btn { padding: 7px 14px; font-size: 12px }
            h1 { font-size: 18px }
            .grid { grid-template-columns: repeat(2, 1fr); gap: 10px }
            .card-body { padding: 8px }
            .name { font-size: 12px }
            .price { font-size: 14px }
            .qty { padding: 5px; font-size: 12px }
            .add { padding: 7px; font-size: 12px }
            .modal-content { padding: 12px; border-radius: 10px }
            .modal-title { font-size: 15px }
            .form-group input, .form-group textarea { padding: 7px; font-size: 13px }
            .btn-checkout { padding: 9px; font-size: 13px }
        }
        
        @@media (min-width: 481px) and (max-width: 768px) {
            .header-content { flex-wrap: wrap }
            .logo { font-size: 21px; flex: none }
            .grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px }
        }
        
        @@media (min-width: 769px) {
            .header-content { flex-wrap: nowrap }
            .logo { font-size: 24px; text-align: left }
            .grid { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px }
        }
        
        @@media (min-width: 480px) { .grid { grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)) } }
        @@media (min-width: 768px) { .grid { grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)) } }
    </style>
</head>
<body>
    <header class="header">
        <div class="header-content">
            <div class="logo">🥩 @(Model.Config?.NombreTienda ?? "Carnicería")</div>
            <nav class="nav">
                <a href="/Admin/Login" class="btn btn-admin">🔐 Admin</a>
                <button class="btn btn-cart" onclick="abrirCarrito()">🛒 (<span id="cartCount">0</span>)</button>
            </nav>
        </div>
    </header>
    
    <main class="main">
        <h1>@ViewData["Title"]</h1>
        
        @if (Model.Productos?.Any() == true)
        {
            <div class="grid">
                @foreach (var p in Model.Productos.Where(x => x.Activo))
                {
                    <div class="card">
                        <img src="@(p.ImagenUrl ?? "https://via.placeholder.com/300")" alt="@p.Nombre" onerror="this.src='https://via.placeholder.com/300'">
                        <div class="card-body">
                            <div class="name">@p.Nombre</div>
                            <div class="price">$@p.PrecioPorKilo.ToString("F2")/kg</div>
                            <input type="number" class="qty" id="q-@p.Id" min="0.5" step="0.5" value="1">
                            <button class="add" onclick="agregar(@p.Id, '@p.Nombre', @p.PrecioPorKilo)">Agregar</button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty">
                <h2>📭 Sin productos</h2>
                <p>Pronto vamos a tener cortes frescos para vos</p>
            </div>
        }
    </main>
    
    <!-- Modal del carrito -->
    <div id="modalCarrito" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">🛒 Tu Pedido</h3>
                <button class="modal-close" onclick="cerrarCarrito()">&times;</button>
            </div>
            <div id="cartItems"></div>
            <div class="cart-total">Total: $<span id="cartTotal">0.00</span></div>
            <button class="btn-checkout" onclick="finalizarCompra()">✅ Finalizar por WhatsApp</button>
        </div>
    </div>
    
    <!-- Modal de datos del comprador -->
    <div id="modalDatos" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">📋 Tus Datos</h3>
                <button class="modal-close" onclick="cerrarDatos()">&times;</button>
            </div>
            <div class="form-group">
                <label>👤 Nombre *</label>
                <input type="text" id="compradorNombre" placeholder="Juan Pérez" required>
            </div>
            <div class="form-group">
                <label>📱 Teléfono *</label>
                <input type="tel" id="compradorTelefono" placeholder="2317401729" required>
            </div>
            <div class="form-group">
                <label>📍 Dirección *</label>
                <input type="text" id="compradorDireccion" placeholder="Calle 123" required>
            </div>
            <div class="form-group">
                <label>📝 Notas</label>
                <textarea id="compradorNotas" rows="2" placeholder="Cortar fino"></textarea>
            </div>
            <button class="btn-checkout" onclick="enviarWhatsApp()">📲 Enviar Pedido</button>
        </div>
    </div>
    
    <!-- Footer profesional -->
    <footer class="footer">
        <div class="footer-content">
            <div>
                Desarrollado por 
                <a href="mailto:dariovaldes@hotmail.com" class="footer-developer">Darío Ricardo Valdés</a> 
                - Analista de Sistemas
            </div>
            <div class="footer-contact">
                <a href="https://wa.me/5492317401729" target="_blank" rel="noopener">📱 +54 9 2317 401729</a>
                <a href="mailto:dariovaldes@hotmail.com">✉️ dariovaldes@hotmail.com</a>
            </div>
            <div class="footer-version">
                <span class="footer-flag">🇦🇷</span> Argentina | 
                Sistema para Ventas por WhatsApp | Versión 1.0
            </div>
        </div>
    </footer>
    
    <script>
        const tienda = '@(Model.Config?.NombreTienda ?? "Mi Carnicería")';
        const whatsappVendedor = '@(Model.Config?.Whatsapp ?? "5492317401729")';
        const aliasMP = '@(Model.Config?.AliasMercadoPago ?? "")';
        const cbu = '@(Model.Config?.Cbu ?? "")';
        const instrucciones = '@(Model.Config?.InstruccionesPago ?? "Una vez confirmado el pago, preparamos tu pedido.")';
        
        function getCarrito() { return JSON.parse(localStorage.getItem('carrito') || '[]'); }
        function guardarCarrito(c) { localStorage.setItem('carrito', JSON.stringify(c)); actualizarContador(); }
        function actualizarContador() {
            const c = getCarrito();
            document.getElementById('cartCount').textContent = c.reduce((s, i) => s + i.cantidad, 0);
        }
        function agregar(id, nombre, precio) {
            const qty = parseFloat(document.getElementById('q-' + id).value) || 1;
            let c = getCarrito();
            const e = c.find(x => x.id === id);
            if (e) e.cantidad += qty; else c.push({ id, nombre, precioPorKilo: precio, cantidad: qty });
            guardarCarrito(c);
            alert('✅ Agregado: ' + nombre + ' x' + qty + 'kg');
        }
        function abrirCarrito() {
            const c = getCarrito();
            const itemsDiv = document.getElementById('cartItems');
            const totalSpan = document.getElementById('cartTotal');
            if (c.length === 0) {
                itemsDiv.innerHTML = '<p style="text-align:center;color:#666;padding:20px">🛒 Vacío</p>';
                totalSpan.textContent = '0.00';
            } else {
                let html = '', total = 0;
                c.forEach((item, idx) => {
                    const subtotal = item.precioPorKilo * item.cantidad;
                    total += subtotal;
                    html += '<div class="cart-item"><div><strong>' + item.nombre + '</strong><br>$' + item.precioPorKilo.toFixed(2) + '/kg x ' + item.cantidad + 'kg</div><div><strong>$' + subtotal.toFixed(2) + '</strong> <button onclick="eliminar(' + idx + ')" style="background:#dc3545;color:white;border:none;border-radius:4px;padding:2px 8px;cursor:pointer;margin-left:10px">&times;</button></div></div>';
                });
                itemsDiv.innerHTML = html;
                totalSpan.textContent = total.toFixed(2);
            }
            document.getElementById('modalCarrito').classList.add('show');
        }
        function cerrarCarrito() { document.getElementById('modalCarrito').classList.remove('show'); }
        function cerrarDatos() { document.getElementById('modalDatos').classList.remove('show'); }
        function eliminar(idx) { let c = getCarrito(); c.splice(idx, 1); guardarCarrito(c); abrirCarrito(); }
        function finalizarCompra() {
            const c = getCarrito();
            if (c.length === 0) { alert('Tu carrito está vacío'); return; }
            cerrarCarrito();
            document.getElementById('modalDatos').classList.add('show');
        }
        function enviarWhatsApp() {
            const nombre = document.getElementById('compradorNombre').value.trim();
            const telefono = document.getElementById('compradorTelefono').value.trim();
            const direccion = document.getElementById('compradorDireccion').value.trim();
            const notas = document.getElementById('compradorNotas').value.trim();
            if (!nombre || !telefono || !direccion) { alert('Completá los campos obligatorios (*)'); return; }
            const c = getCarrito();
            let mensaje = '🥩 *NUEVO PEDIDO - ' + tienda + '*\n\n📦 *Productos:*\n', total = 0;
            c.forEach(item => { const subtotal = item.precioPorKilo * item.cantidad; total += subtotal; mensaje += '• ' + item.nombre + ' x' + item.cantidad + 'kg - $' + subtotal.toFixed(2) + '\n'; });
            mensaje += '\n💰 *Total: $' + total.toFixed(2) + '*\n\n👤 *Datos:*\n• Nombre: ' + nombre + '\n• Teléfono: ' + telefono + '\n• Dirección: ' + direccion;
            if (notas) mensaje += '\n• Notas: ' + notas;
            mensaje += '\n\n💳 *Pago:* Transferencia / Mercado Pago';
            if (aliasMP) mensaje += '\n🟡 Alias MP: `' + aliasMP + '`';
            if (cbu) mensaje += '\n🏦 CBU: `' + cbu + '`';
            mensaje += '\n\n📋 ' + instrucciones;
            mensaje += '\n\n✅ *Próximos pasos:*\n1. Realizar el pago\n2. Enviar comprobante por este chat\n3. Recibir confirmación\n\n¡Gracias! 🙏';
            const url = 'https://wa.me/' + whatsappVendedor + '?text=' + encodeURIComponent(mensaje);
            window.open(url, '_blank', 'noopener,noreferrer');
            localStorage.removeItem('carrito');
            actualizarContador();
            cerrarDatos();
            alert('✅ Pedido enviado por WhatsApp');
        }
        document.getElementById('modalCarrito').addEventListener('click', e => { if (e.target.id === 'modalCarrito') cerrarCarrito(); });
        document.getElementById('modalDatos').addEventListener('click', e => { if (e.target.id === 'modalDatos') cerrarDatos(); });
        document.addEventListener('DOMContentLoaded', actualizarContador);
    </script>
</body>
</html>
