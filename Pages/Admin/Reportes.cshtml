@page "/Admin/Reportes"
@model CarniceriaWhatsApp.Pages.Admin.ReportesModel
@{
    ViewData["Title"] = "Reportes";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>@ViewData["Title"] - Admin</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}body{font-family:system-ui,sans-serif;background:#f5f5f5;min-height:100vh}.header{background:white;padding:15px;box-shadow:0 2px 5px rgba(0,0,0,0.1)}.header-content{max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;align-items:center}.logo{font-size:20px;font-weight:bold;color:#333}.nav a{margin-left:15px;text-decoration:none;color:#667eea;font-weight:600}.main{max-width:1200px;margin:0 auto;padding:20px}h1{color:#333;margin-bottom:20px}.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:15px;margin-bottom:25px}.card{background:white;padding:18px;border-radius:10px;box-shadow:0 3px 10px rgba(0,0,0,0.1)}.card-title{font-size:13px;color:#666;margin-bottom:6px}.card-value{font-size:24px;font-weight:bold;color:#333}.section{background:white;padding:18px;border-radius:10px;box-shadow:0 3px 10px rgba(0,0,0,0.1);margin-bottom:20px}.section-title{font-size:16px;font-weight:bold;color:#333;margin-bottom:12px}.table{width:100%;border-collapse:collapse;font-size:13px}.table th,.table td{padding:10px;text-align:left;border-bottom:1px solid #eee}.table th{background:#f8f9fa;font-weight:600}.badge{padding:3px 8px;border-radius:4px;font-size:11px;font-weight:600}.badge-pendiente{background:#fff3cd;color:#856404}.badge-confirmado{background:#d1ecf1;color:#0c5460}.badge-entregado{background:#c3e6cb;color:#0b5131}
    </style>
</head>
<body>
    <header class="header">
        <div class="header-content">
            <div class="logo">📊 Admin</div>
            <nav class="nav">
                <a href="/">🏪 Tienda</a>
                <a href="/Admin/Productos">📦 Productos</a>
                <a href="/Admin/Configuracion">⚙️ Config</a>
            </nav>
        </div>
    </header>
    
    <main class="main">
        <h1>📊 Reportes</h1>
        
        <!-- Tarjetas de resumen -->
        <div class="cards">
            <div class="card">
                <div class="card-title">Total Vendido</div>
                <div class="card-value">$@(Model.Reporte?.TotalVentas.ToString("F2") ?? "0.00")</div>
            </div>
            <div class="card">
                <div class="card-title">Total Pedidos</div>
                <div class="card-value">@Model.Reporte?.TotalPedidos</div>
            </div>
            <div class="card">
                <div class="card-title">Ticket Promedio</div>
                <div class="card-value">$@(Model.Reporte?.TicketPromedio.ToString("F2") ?? "0.00")</div>
            </div>
            <div class="card">
                <div class="card-title">Período</div>
                <div class="card-value">@Model.Dias días</div>
            </div>
        </div>
        
        <!-- Productos más vendidos -->
        <div class="section">
            <h2 class="section-title">🏆 Productos Más Vendidos</h2>
            @if(Model.Reporte?.ProductosMasVendidos?.Count > 0)
            {
                <table class="table">
                    <thead>
                        <tr><th>Producto</th><th>Cantidad</th><th>Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach(var prod in Model.Reporte.ProductosMasVendidos)
                        {
                            <tr>
                                <td>@prod.Nombre</td>
                                <td>@prod.CantidadVendida.ToString("F2") kg</td>
                                <td>$@prod.TotalVendido.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="text-align:center;color:#666;padding:15px">📭 Sin datos aún</p>
            }
        </div>
        
        <!-- Pedidos por estado -->
        <div class="section">
            <h2 class="section-title">📋 Pedidos por Estado</h2>
            @if(Model.Reporte?.VentasPorEstado?.Count > 0)
            {
                <table class="table">
                    <thead>
                        <tr><th>Estado</th><th>Cantidad</th><th>Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach(var estado in Model.Reporte.VentasPorEstado)
                        {
                            var badge = estado.Estado == "pendiente" ? "badge-pendiente" : estado.Estado == "confirmado" ? "badge-confirmado" : "badge-entregado";
                            <tr>
                                <td><span class="badge @badge">@estado.Estado</span></td>
                                <td>@estado.Cantidad</td>
                                <td>$@estado.Total.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="text-align:center;color:#666;padding:15px">📭 Sin datos aún</p>
            }
        </div>
    </main>
</body>
</html>
