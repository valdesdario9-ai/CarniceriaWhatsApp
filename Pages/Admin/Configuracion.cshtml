@page "/Admin/Configuracion"
@model CarniceriaWhatsApp.Pages.Admin.ConfiguracionModel
@{
    ViewData["Title"] = "Configuración";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#667eea" />
    <title>@ViewData["Title"]</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; flex-direction: column }
        .header { background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1); padding: 15px }
        .header-content { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px }
        .logo { font-size: 20px; font-weight: bold; color: #333; text-decoration: none }
        .btn { padding: 10px 16px; border: none; cursor: pointer; border-radius: 8px; text-decoration: none; display: inline-block; font-size: 14px; font-weight: 600 }
        .btn-primary { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white }
        .main-content { flex: 1; max-width: 900px; margin: 0 auto; padding: 20px; width: 100% }
        .page-title { font-size: 22px; margin-bottom: 20px; color: white; text-align: center }
        .form-container { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.2) }
        .form-section { margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #eee }
        .form-section h3 { color: #333; margin-bottom: 15px; font-size: 18px }
        .form-group { margin-bottom: 20px }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 600; color: #333; font-size: 14px }
        .form-group input, .form-group textarea { width: 100%; padding: 12px; border: 2px solid #ddd; border-radius: 8px; font-size: 14px }
        .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #667eea }
        .form-group textarea { min-height: 80px; resize: vertical }
        .form-group small { color: #666; display: block; margin-top: 5px; font-size: 13px }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px }
        .alert { padding: 12px; border-radius: 8px; margin-bottom: 20px; font-weight: 500 }
        .alert-success { background: #d4edda; color: #155724 }
        .alert-error { background: #f8d7da; color: #721c24 }
        .footer { background: #333; color: white; padding: 20px; text-align: center; margin-top: auto }
        @@media(max-width: 768px) {
            .header-content { flex-direction: column; align-items: stretch }
            .form-row { grid-template-columns: 1fr }
            .form-container { padding: 20px }
            .btn { width: 100%; text-align: center }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="header-content">
            <a href="/" class="logo">🥩 Admin</a>
            <a href="/Admin/Productos" class="btn btn-primary">📦 Productos</a>
        </div>
    </header>
    
    <main class="main-content">
        <h1 class="page-title">⚙️ Configuración de la Carnicería</h1>
        <div class="form-container">
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.IsError ? "alert-error" : "alert-success")">@Model.Message</div>
            }
            
            <form method="post">
                <input type="hidden" name="Config.Id" value="@(Model.Config?.Id ?? 0)" />
                
                <div class="form-section">
                    <h3>📋 Información Básica</h3>
                    <div class="form-group">
                        <label>🏪 Nombre de la Carnicería:</label>
                        <input type="text" name="Config.NombreTienda" required value="@(Model.Config?.NombreTienda ?? "")" placeholder="Ej: Carnicería Don José" />
                    </div>
                    <div class="form-group">
                        <label>📝 Descripción:</label>
                        <textarea name="Config.Descripcion" rows="3" placeholder="Breve descripción de tu carnicería">@(Model.Config?.Descripcion ?? "")</textarea>
                    </div>
                </div>
                
                <div class="form-section">
                    <h3>📞 Contacto</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>📱 WhatsApp:</label>
                            <input type="text" name="Config.Whatsapp" value="@(Model.Config?.Whatsapp ?? "")" placeholder="5492317401729" />
                        </div>
                        <div class="form-group">
                            <label>📞 Teléfono:</label>
                            <input type="text" name="Config.Telefono" value="@(Model.Config?.Telefono ?? "")" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>✉️ Email:</label>
                        <input type="email" name="Config.Email" value="@(Model.Config?.Email ?? "")" />
                    </div>
                </div>
                
                <div class="form-section">
                    <h3>📍 Ubicación</h3>
                    <div class="form-group">
                        <label>🏠 Dirección:</label>
                        <input type="text" name="Config.Direccion" value="@(Model.Config?.Direccion ?? "")" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>🏙️ Ciudad:</label>
                            <input type="text" name="Config.Ciudad" value="@(Model.Config?.Ciudad ?? "")" />
                        </div>
                        <div class="form-group">
                            <label>🗺️ Provincia:</label>
                            <input type="text" name="Config.Provincia" value="@(Model.Config?.Provincia ?? "")" />
                        </div>
                    </div>
                </div>
                
                <div class="form-section">
                    <h3>🕐 Horarios</h3>
                    <textarea name="Config.Horarios" rows="3" placeholder="Lunes a Sábado: 8:00 - 20:00">@(Model.Config?.Horarios ?? "")</textarea>
                </div>
                
                <div class="form-section">
                    <h3>💳 Pago</h3>
                    <div class="form-group">
                        <label>🟡 Alias Mercado Pago:</label>
                        <input type="text" name="Config.AliasMercadoPago" value="@(Model.Config?.AliasMercadoPago ?? "")" placeholder="mi.carniceria" />
                    </div>
                    <div class="form-group">
                        <label>🏦 CBU/CVU:</label>
                        <input type="text" name="Config.Cbu" value="@(Model.Config?.Cbu ?? "")" />
                    </div>
                    <div class="form-group">
                        <label>📋 Instrucciones de pago:</label>
                        <textarea name="Config.InstruccionesPago" rows="3" placeholder="Una vez confirmado el pago, preparamos tu pedido">@Model.Config?.InstruccionesPago</textarea>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary" style="width:100%;padding:15px;font-size:16px">💾 Guardar Configuración</button>
            </form>
        </div>
    </main>
    
    <footer class="footer">
        <p>&copy; @DateTime.Now.Year - Carnicería WhatsApp Admin</p>
    </footer>
</body>
</html>
